# =============================================================================
# Syncthing Configuration — Continuous File Synchronization
# https://docs.syncthing.net
# =============================================================================
#
# On Railway, the PORT environment variable is injected automatically.
# The entrypoint maps PORT directly to Syncthing's GUI address so that
# Railway's platform health checks and public routing work out of the box.
# You typically do NOT need to set PORT manually — Railway provides it.
#
# All variables below are OPTIONAL unless marked [Required].

# ─── Web UI ─────────────────────────────────────────────────────────────────

# GUI listen address.  The entrypoint sets this automatically from Railway's
# PORT variable.  Override only if you need a specific port / bind address
# different from what Railway assigns.
# Format: <host>:<port>   e.g.  0.0.0.0:9000   or  127.0.0.1:8384
# STGUIADDRESS=0.0.0.0:8384

# ─── Data & Config Paths ────────────────────────────────────────────────────

# Syncthing home directory (config, keys, database).
# Default: /var/syncthing
# STHOMEDIR=/var/syncthing/config

# ─── User / Group IDs ───────────────────────────────────────────────────────

# When the container runs as root, the entrypoint drops privileges to these
# IDs.  On Railway the container runs non-root already, so these are ignored.
PUID=1000
PGID=1000

# ─── Advanced ───────────────────────────────────────────────────────────────

# File creation umask (e.g., 002 for group-writable sync folders).
# UMASK=002

# Extra Linux capabilities for the syncthing binary (setcap syntax).
# Example: PCAP=cap_chown,cap_fowner+ep
# PCAP=

# ─── Syncthing CLI Flags (via STFLAGS) ──────────────────────────────────────
# Pass additional flags to `syncthing` at startup.
# Examples:
#   --no-default-folder   Don't create the default "Sync" folder
#   --no-restart          Don't restart after a crash
# STFLAGS=--no-default-folder
